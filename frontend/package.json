	},
	"devDependencies": {
		"@playwright/test": "1.61.1",
		"@preact/preset-vite": "2.10.5",
		"@testing-library/dom": "8.20.1",
		"@testing-library/preact": "3.2.4",
		"happy-dom": "20.10.6",
		"lasertag": "0.1.5",
		"vite": "8.1.0"
